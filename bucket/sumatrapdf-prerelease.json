    "hash": "37cd6568e8159d4b7b3781050347d69fb0634e1e8f6c0920c85436aeeb2d5376",
    "checkver": {
        "url": "https://files2.sumatrapdfreader.org/software/sumatrapdf/sumatralatest.js",
        "regex": "var sumLatestInstaller64\\s+=\\s+\"(?<url>https.*/prerel/(?<version>.*?)/SumatraPDF-prerel-64.install.exe)\";",
        "replace": "${version}"
    },
    "autoupdate": {
