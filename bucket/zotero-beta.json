    "checkver": {
        "script": [
            "$req = [System.Net.WebRequest]::Create('https://www.zotero.org/download/client/dl?channel=beta&platform=win-x64')",
            "$req.AllowAutoRedirect = $false",
            "$resp = $req.GetResponse()",
            "$location = $resp.Headers['Location']",
            "$resp.Close()",
            "$url_noe = $location -Replace('^.*?beta/(.*?)/.*','$1')",
            "return [System.Uri]::UnescapeDataString($url_noe) + '###' + $url_noe"
        ],
        "regex": "(?<version>.*)###(?<noe>.*)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.zotero.org/client/beta/$matchNoe/Zotero-$matchNoe_x64_setup.exe#/dl.7z"
            },
            "32bit": {
                "url": "https://download.zotero.org/client/beta/$matchNoe/Zotero-$matchNoe_win32_setup.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://download.zotero.org/client/beta/$matchNoe/Zotero-$matchNoe_arm64_setup.exe#/dl.7z"
            }
        }
