    "checkver": {
        "script": [
            "$detail = try { Invoke-WebRequest 'https://www.zotero.org/download/client/dl?channel=beta&platform=win-x64' -MaximumRedirection 0 -ErrorAction Ignore } catch { $_.Exception.Response }",
