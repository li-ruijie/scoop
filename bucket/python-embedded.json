{
    "homepage": "https://www.python.org/",
    "description": "A programming language that lets you work quickly and integrate systems more effectively.",
    "license": "Python-2.0",
    "version": "3.14.4",
    "architecture": {
        "64bit": {
            "url": "https://www.python.org/ftp/python/3.14.4/python-3.14.4-embed-amd64.zip#/python314.zip_",
            "hash": "cda80a9b1e75c0f1b4f9872ca1b417f0d19bce32facc811aea9180e70fad5fb9"
        },
        "32bit": {
            "url": "https://www.python.org/ftp/python/3.14.4/python-3.14.4-embed-win32.zip#/python314.zip_",
            "hash": "30e96fbe2a92c24296dd76201dbf793fb877721060e8348b9b647aebf4306850"
        }
    },
    "checkver": {
        "url": "https://www.python.org/downloads/windows/",
        "re": "Latest Python 3 Release - Python ([\\d\\.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://www.python.org/ftp/python/$version/python-$version-embed-amd64.zip#/python$majorVersion$minorVersion.zip_"
            },
            "32bit": {
                "url": "https://www.python.org/ftp/python/$version/python-$version-embed-win32.zip#/python$majorVersion$minorVersion.zip_"
            }
        },
        "hash": {
            "url": "https://www.python.org/downloads/release/python-$cleanVersion/",
            "find": "(?sm)$basename.*?$md5"
        }
    },
    "post_install": [
        "$parts = $version -split '\\.'",
        "$versionshort = $parts[0] + $parts[1]",
        "$pythonDir = \"$dir\\..\\..\\python\\current\"",
        "if (Test-Path $pythonDir) { cmd /c mklink \"$pythonDir\\python$versionshort.zip\" \"$dir\\python$versionshort.zip_\" }"
    ],
    "uninstaller": {
        "script": [
            "$parts = $version -split '\\.'",
            "$versionshort = $parts[0] + $parts[1]",
            "$symlink = \"$dir\\..\\..\\python\\current\\python$versionshort.zip\"",
            "if (Test-Path $symlink) { Remove-Item $symlink -Force }"
        ]
    }
}
